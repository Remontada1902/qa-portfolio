    {
      "name": "2. Users",
      "item": [
        {
          "name": "супер админ",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  ""
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            },
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "pm.sendRequest({\r",
                  "    url: \"{{base_url}}/login/\",\r",
                  "    method: \"POST\",\r",
                  "    header: {\r",
                  "        \"Content-Type\": \"application/json\"\r",
                  "    },\r",
                  "    body: {\r",
                  "        mode: \"raw\",\r",
                  "        raw: JSON.stringify({\r",
                  "            email: \"ivan.petrov@example.com\",\r",
                  "            password: \"password123\"\r",
                  "        })\r",
                  "    }\r",
                  "}, function (err, response) {\r",
                  "    if (err) {\r",
                  "        console.log(\"Ошибка запроса логина:\", err);\r",
                  "        return;\r",
                  "    }\r",
                  "\r",
                  "    if (!response) {\r",
                  "        console.log(\"Ответ от /login/ не получен\");\r",
                  "        return;\r",
                  "    }\r",
                  "\r",
                  "    let json;\r",
                  "    try {\r",
                  "        json = response.json();\r",
                  "    } catch (e) {\r",
                  "        console.log(\"Ответ не JSON:\", response.text());\r",
                  "        return;\r",
                  "    }\r",
                  "\r",
                  "    if (!json.access_token) {\r",
                  "        console.log(\"В ответе нет access_token:\", json);\r",
                  "        return;\r",
                  "    }\r",
                  "\r",
                  "    pm.environment.set(\"access_token\", json.access_token);\r",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{access_token}}",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/users/",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "users",
                ""
              ]
            }
          },
          "response": []
        },
        {
          "name": "обычный юзер",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  ""
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            },
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "// Отправляем запрос на логин\r",
                  "pm.sendRequest({\r",
                  "    url: \"http://localhost:8000/login/\",\r",
                  "    method: \"POST\",\r",
                  "    header: {\r",
                  "        \"Content-Type\": \"application/json\"\r",
                  "    },\r",
                  "    body: {\r",
                  "        mode: \"raw\",\r",
                  "        raw: JSON.stringify({\r",
                  "            email: \"email@example.com\",\r",
                  "            password: \"12345678\"\r",
                  "        })\r",
                  "    }\r",
                  "}, function (err, response) {\r",
                  "    // Получаем токен из ответа\r",
                  "    const token = response.json().access_token;\r",
                  "    \r",
                  "    // Сохраняем токен в переменную коллекции\r",
                  "    pm.collectionVariables.set(\"access_token\", token);\r",
                  "    \r",
                  "    console.log(\"🔄 Токен обновлён:\", token.substring(0, 30) + \"...\");\r",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{access_token}}",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/users/",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "users",
                ""
              ]
            }
